# API Configuration
VITE_API_BASE_URL=http://localhost:5000
VITE_API_VERSION=v1

# Custom Headers Configuration
# Set to 'true' if your backend supports custom headers like X-Client-IP, X-Device-Info
# Set to 'false' or leave empty to avoid CORS issues
VITE_USE_CUSTOM_HEADERS=false

# Social Login Configuration
# Google OAuth 2.0
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# GitHub OAuth 2.0
VITE_GITHUB_CLIENT_ID=your_github_client_id_here
VITE_GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Facebook OAuth 2.0
VITE_FACEBOOK_APP_ID=your_facebook_app_id_here
